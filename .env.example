# ── API security ────────────────────────────────────────────────────────────
# Secret the VR client must send as `Authorization: Bearer <key>`.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=ixAb2qpFn72tYh03J9-aZ_2oz7wAt21gCnNlwQm8rVI

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: route through an Azure/proxy gateway. Leave blank for api.openai.com.
OPENAI_BASE_URL=
# Generation model used by the Responses API.
OPENAI_MODEL=gpt-4o
REQUEST_TIMEOUT_S=60

# ── Local retrieval (Qdrant + bge-m3 embedder) ────────────────────────────────
# QDRANT_URL / EMBEDDING_BASE_URL point at the docker-compose services
# (qdrant / embedder); they default to localhost for non-docker runs.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=school_kb
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_DIM=1024
# Embed chunks in batches of this many per request (avoids embedder timeouts on
# big documents like ~800-chunk PDFs). <=0 sends everything in one request.
EMBED_BATCH_SIZE=64
# Hybrid retrieval (dense + sparse, RRF fusion).
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=20
RETRIEVAL_SCORE_THRESHOLD=0.0
# Local document chunking.
CHUNK_SIZE=800
CHUNK_OVERLAP=120
# Offline corpus bulk-ingest (scripts/manage_corpus.py). Metadata (subject/
# grade/lang/lab_id) is derived from the folder layout under CORPUS_ROOT.
CORPUS_ROOT=./Лабораторные физхимбио
LABS_MANIFEST=./labs.json
# OCR fallback for scanned/image-only textbooks (opt-in; ingest-time only — the
# serving path never OCRs). Enable per-run with `bulk-ingest --ocr`, or set here.
# Needs the Tesseract binary + rus/kaz data (baked into the api Docker image).
OCR_ENABLED=false
OCR_DPI=200
OCR_MAX_PAGES=0  # 0 = all pages

# ── Voice (in-repo STT/TTS sidecar; the `voice` compose service, ./voice) ─────
# GPU STT/TTS service. STT = Whisper (ru/kk/auto), TTS = supertonic ru + MMS
# kaz. STT/TTS language follows DEFAULT_LANGUAGE below. Under docker compose the
# api talks to it at http://voice:8001; the value below is for local dev against
# the host-mapped port (compose maps host 8002 -> container 8001).
VOICE_BASE_URL=http://localhost:8002
# Plain HTTP over the internal compose network, so verification is moot here.
VOICE_VERIFY_SSL=false
# Generous timeout: covers first-call GPU cold start and up to ~120s of audio.
VOICE_TIMEOUT_S=120

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Primary answer language ('ru' or 'kk'). The assistant always mirrors the
# question language, but this sets the fallback for empty/ambiguous input.
DEFAULT_LANGUAGE=ru
# Max characters accepted in a single user message.
MAX_INPUT_CHARS=4000
# Max tokens the model may generate for a normal answer.
LLM_MAX_TOKENS=600
# Where per-lab scenario JSON documents live.
SCENARIOS_DIR=./scenarios

# ── CORS / limits ─────────────────────────────────────────────────────────────
CORS_ORIGINS=*
# Per client IP. Set to 0 (or negative) to disable rate limiting entirely,
# e.g. for bulk eval runs from a single client.
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_BYTES=26214400

# ── Runtime toggles ───────────────────────────────────────────────────────────
ENABLE_DOCS=true
LOG_LEVEL=INFO
LOG_GENERATION=true
